{
  "name": "datashare-webapp",
  "version": "1.0.9",
  "description": "",
  "homepage": "https://github.com/RkotT0NS/OCR-P4#readme",
  "bugs": {
    "url": "https://github.com/RkotT0NS/OCR-P4/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/RkotT0NS/OCR-P4.git"
  },
  "workspaces": [
    "laravel",
    "figma/implementation",
    "types",
    "tools",
    "e2e",
    "packages/pagination-cache"
  ],
  "license": "ISC",
  "author": "tetedacier",
  "directories": {
    "doc": "docs",
    "test": "test"
  },
  "scripts": {
    "lint": "npm run lint -w @datashare/ui && npm run lint -w @datashare/webapp",
    "docker": "docker compose up",
    "docker:testing": "docker compose -f docker-compose-testing.yml up",
    "docker:stop": "docker compose down",
    "storybook": "npm run storybook -w @datashare/ui",
    "dev:laravel": "npm run dev -w @datashare/webapp",
    "test:clean": "rm -rf laravel/storage/coverage-e2e/*.cov laravel/coverage figma/implementation/stories-coverage e2e/coverage",
    "test": "npm run test:clean &&  npm run test:stories && npm run test:laravel-phpunit && npm run test:e2e && npm run phpunit:merge-coverage",
    "test:result": "npm run test && npm run show:monocart",
    "test:e2e": "npm run test -w @datashare/end-to-end",
    "test:stories": "npm run test -w @datashare/ui",
    "show:monocart": "(cd e2e && npx monocart show-report test-results/report.html)",
    "test:laravel-phpunit": "docker exec laravel_app_test ./vendor/bin/phpunit --coverage-php storage/coverage-e2e/phpunit-base.cov --coverage-html ./coverage/unit",
    "cleanup:phpunit-e2e-coverage": "rm -f laravel/storage/coverage-e2e/*.cov",
    "laravel:lint": "cd laravel && composer run lint",
    "laravel:scribe": "docker exec laravel_app php artisan scribe:generate",
    "laravel:setup": "cd laravel && composer setup",
    "laravel:db-migrate": "docker exec laravel_app php artisan migrate",
    "laravel:db-rollback": "php artisan migrate:rollback",
    "laravel:db-reset": "docker exec laravel_app php artisan migrate:fresh --seed",
    "phpunit:merge-coverage": "docker exec laravel_app_test ./vendor/bin/phpcov merge  --html ./coverage/unified --clover ./unified-clover.xml storage/coverage-e2e",
    "build:internal-dependencies": "npm run build -w @datashare/pagination-cache -w @datashare/types -w @datashare/tools",
    "build:laravel": "npm run build -w @datashare/webapp",
    "watch:laravel": "npm run dev -w @datashare/webapp",
    "laravel:build-frontend-sourcemap": "npm run build -w @datashare/webapp -- --sourcemap true",
    "build:types": "npm run build -w @datashare/types",
    "build:tools": "npm run build -w @datashare/tools",
    "build:pagination-cache": "npm run build -w @datashare/pagination-cache",
    "watch:pagination-cache": "npm run watch -w @datashare/pagination-cache",
    "watch:types": "npm run watch -w @datashare/types"
  }
}
